---
const { studyName, studyType, studyPeriod, studyDescription, mentorNames, leadName } = Astro.props;

interface Props {
	studyName: string;
	studyType: string;
	studyPeriod: string[];
	studyDescription: string;
	mentorNames?: string[];
	leadName?: string | string[];
}

// 멘토가 있으면 멘토, 없으면 리드(운영진 등)를 표시
const leadList = Array.isArray(leadName) ? leadName : leadName ? [leadName] : [];
const people = (mentorNames && mentorNames.length > 0) ? mentorNames : leadList;
const peopleLabel = people.join(", ");
---

<div
	class="group flex flex-col h-full p-6 sm:p-8 rounded-3xl bg-white border border-gray-100 dark:shadow-none dark:border-gray-700 dark:bg-gray-800 bg-opacity-50 shadow-2xl shadow-gray-600/10"
>
	<div class="flex flex-wrap justify-center gap-2 mb-4">
		{studyPeriod.map((period: string) => (
			<span class="bg-gray-100 text-gray-600 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 inline-flex items-center justify-center">
				{period}
			</span>
		))}
		<span class="bg-blue-100 text-blue-800 text-xs font-medium px-2.5 py-0.5 rounded dark:bg-gray-700 dark:text-blue-400 border border-blue-400 inline-flex items-center justify-center">
			{studyType}
		</span>
	</div>
	<h3 class="text-xl font-semibold text-center text-gray-800 dark:text-white">
		{studyName}
	</h3>
	{peopleLabel && (
		<p class="mt-2 text-sm text-center text-primary">{peopleLabel}</p>
	)}
	{studyDescription && (
		<p class="mt-4 text-sm text-center text-gray-600 dark:text-gray-300">
			{studyDescription}
		</p>
	)}
</div>
